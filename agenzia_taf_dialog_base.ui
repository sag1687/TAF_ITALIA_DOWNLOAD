   <item>
    <widget class="QGroupBox" name="groupBox_info">
     <property name="title">
      <string>Info, Disclaimer &amp; Avvertenze</string>
     </property>
     <layout class="QVBoxLayout" name="verticalLayout_4">
      <item>
       <widget class="QLabel" name="label_format_info">
        <property name="text">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;b&gt;📄 Formato Output:&lt;/b&gt; I dati vengono scaricati e convertiti in formato &lt;b&gt;CSV&lt;/b&gt; con coordinate &lt;b&gt;WGS84 (EPSG:4326)&lt;/b&gt;, caricati automaticamente come layer vettoriale in QGIS.&lt;br/&gt;Il file di output segue la nomenclatura: &lt;code&gt;Tabella_Punti_Fiduciari_Area_[SIGLA].csv&lt;/code&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="label_disclaimer_outlier">
        <property name="text">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p style="color:#c0392b;"&gt;&lt;b&gt;⚠️ Avvertenza Outlier:&lt;/b&gt; I dati potrebbero contenere &lt;b&gt;punti outlier&lt;/b&gt; (coordinate anomale) generati da errori nella conversione dei sistemi di riferimento originali (Cassini-Soldner / Gauss-Boaga → WGS84). Si raccomanda di &lt;b&gt;verificare visivamente&lt;/b&gt; i punti e rimuovere eventuali anomalie prima dell'utilizzo professionale.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="label_author">
        <property name="text">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p align="center"&gt;&lt;b&gt;Sviluppo:&lt;/b&gt; Dott. Sarino Alfonso Grande | &lt;b&gt;Web:&lt;/b&gt; &lt;a href="https://sinocloud.it"&gt;sinocloud.it&lt;/a&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="openExternalLinks">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="label_disclaimer">
        <property name="text">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p align="justify"&gt;&lt;b&gt;[ITA]&lt;/b&gt; TAF Italia è un &lt;b&gt;tramite semplificato&lt;/b&gt; per il download dei &lt;b&gt;Punti Fiduciali (TAF)&lt;/b&gt; dall'Agenzia delle Entrate. I dati originali vengono trasformati automaticamente nel sistema di coordinate WGS84 (EPSG:4326) e salvati in formato CSV.&lt;br/&gt;&lt;b&gt;[ENG]&lt;/b&gt; TAF Italia is a &lt;b&gt;simplified bridge&lt;/b&gt; for downloading &lt;b&gt;Fiducial Points (TAF)&lt;/b&gt; from the Italian Revenue Agency. Original data is automatically reprojected into WGS84 (EPSG:4326) and saved as CSV.&lt;br/&gt;&lt;br/&gt;&lt;i&gt;Fonte / Source:&lt;/i&gt; &lt;a href="https://www.agenziaentrate.gov.it/"&gt;Agenzia delle Entrate&lt;/a&gt;&lt;br/&gt;&lt;i&gt;Licenza / License:&lt;/i&gt; Open Data (CC-BY).&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
        <property name="openExternalLinks">
         <bool>true</bool>
        </property>
       </widget>
      </item>
